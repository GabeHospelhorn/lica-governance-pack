{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LICA Incident Short Form",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "system": {
      "type": "string"
    },
    "reporter_role": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "data",
        "model",
        "safety",
        "cyber"
      ]
    },
    "article_73_flags": {
      "type": "object",
      "properties": {
        "serious_harm": {
          "type": "boolean"
        },
        "near_miss": {
          "type": "boolean"
        },
        "systemic_risk": {
          "type": "boolean"
        },
        "recurrence_risk": {
          "type": "boolean"
        }
      },
      "required": [
        "serious_harm",
        "near_miss",
        "systemic_risk",
        "recurrence_risk"
      ]
    },
    "initial_disposition": {
      "type": "string",
      "enum": [
        "run",
        "safe_mode",
        "suspend"
      ]
    },
    "evidence_links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "annex_iv_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "triage": {
      "type": "object",
      "properties": {
        "triage_owner": {
          "type": "string"
        },
        "triage_time_hours": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "escalated",
            "closed"
          ]
        }
      },
      "required": [
        "triage_owner",
        "triage_time_hours",
        "status"
      ]
    },
    "tribunal": {
      "type": "object",
      "properties": {
        "legal": {
          "type": "string"
        },
        "clinical": {
          "type": "string"
        },
        "deadline_hours": {
          "type": "integer"
        },
        "decision_id": {
          "type": "string"
        }
      },
      "required": [
        "legal",
        "clinical",
        "deadline_hours",
        "decision_id"
      ]
    },
    "rca": {
      "type": "object",
      "properties": {
        "due_days": {
          "type": "integer"
        },
        "root_cause": {
          "type": "string"
        },
        "contributing_factors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "corrective_actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "due_days",
        "root_cause",
        "contributing_factors",
        "corrective_actions"
      ]
    }
  },
  "required": [
    "event_id",
    "timestamp",
    "system",
    "reporter_role",
    "event_type",
    "article_73_flags",
    "initial_disposition",
    "evidence_links",
    "annex_iv_refs",
    "triage",
    "tribunal",
    "rca"
  ]
}